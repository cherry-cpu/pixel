# Pixel — AI Photo Memory Manager
# Copy to .env and set your keys (do not commit .env).

# Natural language search (use at least one)
# Groq: fast, recommended for hackathon — https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Hugging Face: fallback if Groq not set — https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Optional: override models
# GROQ_MODEL=llama-3.1-70b-versatile
# HF_MODEL=HuggingFaceH4/zephyr-7b-beta

# Vision: Hugging Face (caption + classification) — https://huggingface.co/settings/tokens
# HF_CAPTION_MODEL=Salesforce/blip-image-captioning-base
# HF_VISION_MODEL=google/vit-base-patch16-224

# Vision: Google Gemini (caption + tags) — https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_VISION_MODEL=gemini-2.0-flash
